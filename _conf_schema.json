{
    "mode": {
        "type": "string",
        "description": "预设模式",
        "hint": "选择沉浸式互动的预设场景",
        "options": ["control", "pet", "teacher", "shy", "tsundere"],
        "default": "control"
    },
    "scope": {
        "type": "string",
        "description": "状态作用范围",
        "hint": "user = 仅触发者受影响，session = 全群所有人消息都会被影响",
        "options": ["user", "session"],
        "default": "user"
    },
    "enter_keywords": {
        "type": "list",
        "description": "进入关键词",
        "hint": "用户发送对应关键词时触发沉浸模式",
        "default": ["我要控制你了"]
    },
    "exit_keywords": {
        "type": "list",
        "description": "退出关键词",
        "hint": "用户发送对应关键词时退出沉浸模式",
        "default": ["拿出来吧", "停止"]
    },
    "extend_keywords": {
        "type": "list",
        "description": "延长关键词",
        "hint": "在沉浸状态中发送对应关键词可延长持续时间",
        "default": ["继续", "再来", "more"]
    },
    "state_duration": {
        "type": "int",
        "description": "持续时间（秒）",
        "hint": "每次沉浸状态持续的时间",
        "slider": {"min": 10, "max": 600, "step": 1},
        "default": 180
    },
    "extend_duration": {
        "type": "int",
        "description": "每次延长时间（秒）",
        "hint": "发送延长关键词时增加的时间",
        "slider": {"min": 10, "max": 300, "step": 1},
        "default": 60
    },
    "cooldown_user": {
        "type": "int",
        "description": "每用户冷却（秒）",
        "hint": "同一用户连续触发的冷却时间",
        "slider": {"min": 0, "max": 120, "step": 1},
        "default": 30
    },
    "cooldown_group": {
        "type": "int",
        "description": "每群冷却（秒）",
        "hint": "同一群聊连续触发的冷却时间",
        "slider": {"min": 0, "max": 300, "step": 1},
        "default": 60
    },
    "sensitivity": {
        "type": "int",
        "description": "敏感度（0-100）",
        "hint": "默认敏感度，/控制可覆盖",
        "slider": {"min": 0, "max": 100, "step": 1},
        "default": 50
    },
    "curve": {
        "type": "string",
        "description": "强度曲线",
        "hint": "flat = 固定，ramp_up = 逐步增强，decay = 逐渐消退，wave = 波动起伏",
        "options": ["flat", "ramp_up", "decay", "wave"],
        "default": "flat"
    },
    "afterglow_enable": {
        "type": "bool",
        "description": "启用余韵阶段",
        "hint": "退出后 Bot 会慢慢恢复",
        "default": true
    },
    "afterglow_duration": {
        "type": "int",
        "description": "余韵持续时间（秒）",
        "hint": "余韵阶段的持续时间",
        "slider": {"min": 0, "max": 120, "step": 1},
        "default": 30
    },
    "item_name": {
        "type": "string",
        "description": "装置名称",
        "hint": "在提示词中显示的装置名称",
        "default": "特殊装置"
    },
    "group_whitelist": {
        "type": "list",
        "description": "群聊白名单",
        "hint": "为空则不限制",
        "default": []
    },
    "admin_only_mode": {
        "type": "bool",
        "description": "仅管理员可用",
        "hint": "开启后只有管理员可以触发沉浸模式",
        "default": false
    },
    "waiting_timeout": {
        "type": "int",
        "description": "等待超时（秒）",
        "hint": "/tp_st 远程启动后等待用户响应的超时时间",
        "slider": {"min": 30, "max": 600, "step": 10},
        "default": 300
    },
    "remote_msg": {
        "type": "string",
        "description": "远程启动提示消息",
        "hint": "/tp_st 启动后显示的提示消息，留空使用默认",
        "default": ""
    },
    "tp_st_admin_only": {
        "type": "bool",
        "description": "/tp_st 仅管理员可用",
        "hint": "开启后只有管理员可以使用 /tp_st",
        "default": false
    },
    "tp_st_cooldown": {
        "type": "int",
        "description": "/tp_st 冷却时间（秒）",
        "hint": "使用 /tp_st 后的冷却时间",
        "slider": {"min": 0, "max": 300, "step": 1},
        "default": 30
    },
    "custom_enter_prompt": {
        "type": "text",
        "description": "自定义进入沉浸模式提示词",
        "hint": "清空此字段则使用内置预设（5种模式随机选择）。填写自定义内容后将固定使用此提示词。支持 {item_name} 占位符。示例：你是一个被神奇装置「{item_name}」影响的角色，会做出害羞、紧张等反应。",
        "default": ""
    },
    "custom_afterglow_prompt": {
        "type": "text",
        "description": "自定义余韵阶段提示词",
        "hint": "清空此字段则使用内置预设。支持 {item_name} 占位符。示例：你刚从「{item_name}」的影响中恢复，身体还有余韵。",
        "default": ""
    },
    "custom_exit_prompt": {
        "type": "text",
        "description": "自定义退出沉浸模式提示词",
        "hint": "清空此字段则使用内置预设。支持 {item_name} 占位符。示例：你已完全恢复正常，用平常方式自然对话。",
        "default": ""
    },
    "custom_presets": {
        "type": "template_list",
        "description": "自定义预设列表",
        "hint": "创建自定义预设后，可通过 /mc_mode 预设名 切换。",
        "templates": {
            "preset": {
                "name": "自定义预设",
                "hint": "定义一个新的沉浸模式预设",
                "items": {
                    "name": {
                        "description": "预设名称",
                        "hint": "用 /mc_mode 此名称 来切换到此预设",
                        "type": "string",
                        "default": ""
                    },
                    "enter": {
                        "description": "进入沉浸模式时的提示词",
                        "hint": "Bot进入沉浸模式时注入的提示词，支持 {item_name} 占位符",
                        "type": "text",
                        "default": ""
                    },
                    "afterglow": {
                        "description": "余韵阶段的提示词",
                        "hint": "退出沉浸模式后余韵阶段的提示词",
                        "type": "text",
                        "default": ""
                    },
                    "exit": {
                        "description": "退出沉浸模式时的提示词",
                        "hint": "Bot完全恢复时的提示词",
                        "type": "text",
                        "default": ""
                    }
                }
            }
        },
        "default": []
    },
    "enter_msg_enable": {
        "type": "bool",
        "description": "发送进入提示消息",
        "hint": "开启后进入沉浸模式时直接发送一条文字消息（不经过LLM）。关闭则由LLM根据提示词回复。",
        "default": false
    },
    "enter_msg_text": {
        "type": "string",
        "description": "进入沉浸模式提示消息",
        "hint": "开启「发送进入提示消息」后，进入时发送的文字内容。留空使用默认消息。",
        "default": ""
    },
    "exit_msg_enable": {
        "type": "bool",
        "description": "发送退出提示消息",
        "hint": "开启后退出沉浸模式时直接发送一条文字消息（不经过LLM）。关闭则由LLM根据提示词回复。",
        "default": false
    },
    "exit_msg_text": {
        "type": "string",
        "description": "退出沉浸模式提示消息",
        "hint": "开启「发送退出提示消息」后，退出时发送的文字内容。留空使用默认消息。",
        "default": ""
    }
}