{
    "mode": {
        "type": "string",
        "description": "预设模式",
        "hint": "选择内置模式（control/pet/teacher/shy/tsundere）或输入你自定义预设的名称",
        "default": "control"
    },
    "scope": {
        "type": "string",
        "description": "状态作用范围",
        "hint": "user = 仅触发者受影响，session = 全群所有人消息都会被影响",
        "options": ["user", "session"],
        "default": "user"
    },
    "enter_keywords": {
        "type": "list",
        "description": "进入关键词",
        "hint": "用户发送对应关键词时触发沉浸模式",
        "default": ["我要控制你了"]
    },
    "exit_keywords": {
        "type": "list",
        "description": "退出关键词",
        "hint": "用户发送对应关键词时退出沉浸模式",
        "default": ["拿出来吧", "停止"]
    },
    "extend_keywords": {
        "type": "list",
        "description": "延长关键词",
        "hint": "在沉浸状态中发送对应关键词可延长持续时间",
        "default": ["继续", "再来", "more"]
    },
    "state_duration": {
        "type": "int",
        "description": "持续时间（秒）",
        "hint": "每次沉浸状态持续的时间",
        "slider": {"min": 10, "max": 600, "step": 1},
        "default": 180
    },
    "extend_duration": {
        "type": "int",
        "description": "每次延长时间（秒）",
        "hint": "发送延长关键词时增加的时间",
        "slider": {"min": 10, "max": 300, "step": 1},
        "default": 60
    },
    "cooldown_user": {
        "type": "int",
        "description": "每用户冷却（秒）",
        "hint": "同一用户连续触发的冷却时间",
        "slider": {"min": 0, "max": 120, "step": 1},
        "default": 30
    },
    "cooldown_group": {
        "type": "int",
        "description": "每群冷却（秒）",
        "hint": "同一群聊连续触发的冷却时间",
        "slider": {"min": 0, "max": 300, "step": 1},
        "default": 60
    },
    "sensitivity": {
        "type": "int",
        "description": "敏感度（0-100）",
        "hint": "默认敏感度，/控制可覆盖",
        "slider": {"min": 0, "max": 100, "step": 1},
        "default": 50
    },
    "curve": {
        "type": "string",
        "description": "强度曲线",
        "hint": "flat = 固定，ramp_up = 逐步增强，decay = 逐渐消退，wave = 波动起伏",
        "options": ["flat", "ramp_up", "decay", "wave"],
        "default": "flat"
    },
    "afterglow_enable": {
        "type": "bool",
        "description": "启用余韵阶段",
        "hint": "退出后 Bot 会慢慢恢复",
        "default": true
    },
    "afterglow_duration": {
        "type": "int",
        "description": "余韵持续时间（秒）",
        "hint": "余韵阶段的持续时间",
        "slider": {"min": 0, "max": 120, "step": 1},
        "default": 30
    },
    "item_name": {
        "type": "string",
        "description": "装置名称",
        "hint": "在提示词中显示的装置名称",
        "default": "特殊装置"
    },
    "group_whitelist": {
        "type": "list",
        "description": "群聊白名单",
        "hint": "为空则不限制",
        "default": []
    },
    "admin_only_mode": {
        "type": "bool",
        "description": "仅管理员可用",
        "hint": "开启后只有管理员可以触发沉浸模式",
        "default": false
    },
    "custom_presets": {
        "type": "template_list",
        "description": "自定义预设模式",
        "hint": "你可以在这里添加自己的预设模式。每个预设需要包含 enter（进入）、afterglow（余韵）、exit（退出）三种提示词模板。添加后可以在「预设模式」中选择。",
        "templates": {
            "custom": {
                "name": "自定义预设",
                "hint": "自定义预设模式",
                "display_item": "name",
                "items": {
                    "name": {
                        "description": "预设名称（用于在 mode 中选择）",
                        "type": "string",
                        "default": ""
                    },
                    "enter": {
                        "description": "进入提示词模板（可用 {item_name} 和 {sensitivity} 占位符）",
                        "type": "text",
                        "default": ""
                    },
                    "afterglow": {
                        "description": "余韵提示词模板",
                        "type": "text",
                        "default": ""
                    },
                    "exit": {
                        "description": "退出提示词模板",
                        "type": "text",
                        "default": ""
                    }
                }
            }
        }
    }
}
